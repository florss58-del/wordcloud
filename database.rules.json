{
  "rules": {
    ".read": false,
    ".write": false,

    "instructors": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "sessions": {
          "$code": {
            ".validate": "newData.hasChildren(['name', 'created'])",
            "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
            "q": { ".validate": "newData.isString() && newData.val().length <= 80" },
            "mode": { ".validate": "newData.val() === 'word' || newData.val() === 'phrase'" },
            "max": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
            "created": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "sessions": {
      ".read": "auth != null",

      "$code": {
        ".read": true,

        "meta": {
          ".write": "auth != null && !data.exists() && newData.exists()",
          ".validate": "newData.hasChildren(['q', 'max', 'mode', 'name', 'created'])",
          "q": { ".write": "auth != null", ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 80" },
          "max": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5" },
          "mode": { ".validate": "newData.val() === 'word' || newData.val() === 'phrase'" },
          "name": { ".write": "auth != null", ".validate": "newData.isString() && newData.val().length <= 40" },
          "created": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        },

        "entries": {
          ".write": "auth != null && !newData.exists()",
          "$entryId": {
            ".write": "!data.exists() && newData.exists() && root.child('sessions').child($code).child('meta').exists() && root.child('sessions').child($code).child('closed').val() !== true",
            ".validate": "newData.hasChildren(['w', 'c', 't'])",
            "w": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
            "c": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64" },
            "t": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "hidden": {
          ".write": "auth != null",
          "$word": { ".validate": "newData.val() === true" }
        },

        "closed": {
          ".write": "auth != null",
          ".validate": "newData.isBoolean()"
        },

        "$other": { ".validate": false }
      }
    }
  }
}
